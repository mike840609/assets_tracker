const created = new Date("2026-01-01T00:00:00.000Z");

function account(over: Record<string, unknown> = {}) {
  return {
    id: "acc",
    userId: "u1",
    name: "Cash",
    type: "ASSET",
    category: "BANK",
    currency: "USD",
    cashBalance: 1100,

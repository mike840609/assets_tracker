<file path="docs/firewall_rules.json">
{
  "$comment": "P2 — Vercel Firewall rules spec. Consolidated to 3 rules to fit the Hobby-plan custom-rule cap. Rules 1 and 2 overlap intentionally (e.g. /wp-admin/install.php matches both); the firewall short-circuits on first match, so duplication is harmless and gives us redundant coverage. Apply via Vercel dashboard (Project → Settings → Firewall → Custom Rules) or the REST API. Re-export after each dashboard change so this file stays in sync.",
  "project": "asset-tracker",
  "team": "mike840609s-projects",
  "rules": [
    {
      "name": "block-extensions-and-dotfiles",
      "active": true,
      "action": { "mitigate": { "action": "deny" } },
      "conditionGroup": [
        {
          "conditions": [
            {
              "type": "path",
              "op": "re",
              "value": "\\.(php|aspx?|jsp|cgi|env|git|svn|htaccess|htpasswd)($|\\?|/)"
            }
          ]
        }
      ],
      "description": "Broadest single rule — denies any path containing tell-tale credential/source/script extensions: .php, .asp, .aspx, .jsp, .cgi, .env, .git, .svn, .htaccess, .htpasswd. The app is Next.js and has zero legitimate paths in those families. Catches /wp-admin/install.php (observed 2026-05-17), /xmlrpc.php, /.env, /.git/config, etc."
    },
    {
      "name": "block-bot-prefixes",
      "active": true,
      "action": { "mitigate": { "action": "deny" } },
      "conditionGroup": [
        {
          "conditions": [
            {
              "type": "path",
              "op": "re",
              "value": "^/(wp-admin|wp-login|wp-content|wp-includes|wordpress|xmlrpc|cmd_|phpmyadmin|pma|adminer|vendor/phpunit|cgi-bin)"
            }
          ]
        }
      ],
      "description": "Denies bot/scanner path prefixes that don't necessarily carry a tell-tale extension. Required because rule 1 alone wouldn't catch /cmd_sco (no extension) or /wp-admin/ (directory probes). Catches /cmd_sco (observed 2026-05-17), /wp-admin/, /wp-content/uploads/..., /phpmyadmin/, /adminer.php, /vendor/phpunit/..."
    },
    {
      "name": "rate-limit-public-pages",
      "active": true,
      "action": {
        "mitigate": {
          "action": "rate_limit",
          "rateLimit": { "limit": 30, "windowSeconds": 60 }
        }
      },
      "conditionGroup": [
        {
          "conditions": [
            { "type": "path", "op": "re", "value": "^/(login|privacy|terms)$" },
            { "type": "method", "op": "eq", "value": "GET" }
          ]
        }
      ],
      "description": "Caps aggressive scrapers on the three public pages without blocking humans. Logs on 2026-05-17 showed 5×/sec /privacy bursts from a scraper grabbing sub-resources per page load. 30 req / 60 s per IP is well above any human pattern."
    }
  ]
}

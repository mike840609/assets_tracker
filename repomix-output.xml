    updatedAt: created,
    ...over,
  };
}
function account(
  over: Partial<AccountFixture> & Pick<AccountFixture, "id" | "currency" | "type">,
): AccountFixture {
  return {
    userId: "u1",
    name: over.id,
    category: "INVESTMENT",
    cashBalance: 0,
    isActive: true,
    isPinned: false,
    sortOrder: 0,
    createdAt: created,
    updatedAt: created,
    holdings: [],
    ...over,
  };
}


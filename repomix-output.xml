/* Warning toast lane — the warning icon is configured in sonner.tsx; tint it and
   the border with --warning so toast.warning() reads as caution, not error. */
[data-sonner-toast][data-type="warning"] [data-icon] {
  color: var(--warning);
}
[data-sonner-toast][data-type="warning"] {
  border-color: color-mix(in oklch, var(--warning) 40%, var(--border));
}

/* Sonner toast action button — theme-aware outline style */
[data-sonner-toast][data-styled="true"] [data-action] {
  background: var(--muted) !important;
  color: var(--foreground) !important;
  border: 1px solid var(--border) !important;
  border-radius: var(--radius-sm) !important;
  height: 30px !important;
  padding-left: 16px !important;
  padding-right: 16px !important;
  min-width: 56px !important;
  font-weight: 500 !important;
}

[data-sonner-toast][data-styled="true"] [data-action]:hover {
  background: var(--accent) !important;
  color: var(--accent-foreground) !important;
}

/* Slide in from right, slide out to right for top-right toaster.
   Sonner animates via --y which is applied as transform: var(--y). */
[data-sonner-toaster][data-x-position="right"]
  [data-sonner-toast][data-y-position="top"]:not([data-mounted="true"]) {
  --y: translateX(calc(100% + 1rem)) !important;
}

[data-sonner-toaster][data-x-position="right"]
  [data-sonner-toast][data-y-position="top"][data-removed="true"][data-swipe-out="false"] {
  --y: translateX(calc(100% + 1rem)) !important;
}

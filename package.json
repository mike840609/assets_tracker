{
  "name": "asset_app",
  "version": "0.6.0",
  "private": true,
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "node scripts/check-node-version.mjs && prisma generate && node scripts/print-db-connection.mjs && next dev -H 0.0.0.0",
    "build": "next build",
    "build:vercel": "node scripts/vercel-build.mjs",
    "audit:build-cache": "node scripts/ci/build-cache-audit.mjs",
    "sentry:setup": "node scripts/setup-sentry-monitoring.mjs",
    "start": "next start",
    "analyze": "ANALYZE=true next build",
    "compress:og": "node scripts/compress-og-images.mjs",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm build",
    "postinstall": "prisma generate",
    "setup:worktree": "node scripts/setup-worktree.mjs",
    "prepare": "husky",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "db:up": "docker-compose up -d",
    "db:down": "docker-compose down"
  },
  "lint-staged": {
    "**/*.{ts,tsx,mjs,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@base-ui/react": "^1.3.0",
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-neon": "^7.6.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@radix-ui/react-slot": "^1.2.5",
    "@sentry/core": "^10.57.0",
    "@sentry/nextjs": "^10.57.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "next-auth": "^5.0.0-beta.30",
    "next-intl": "^4.9.0",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.0",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "web-vitals": "^5.2.0",
    "ws": "^8.20.0",
    "yahoo-finance2": "^3.14.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.4",
    "@next/env": "^16.2.9",
    "@playwright/test": "^1.52.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.3",
    "prettier": "^3.8.3",
    "prisma": "^7.6.0",
    "shadcn": "^4.1.2",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}

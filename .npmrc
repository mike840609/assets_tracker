# pnpm configuration (committed, machine-agnostic).
#
# Do NOT set an absolute `store-dir` here — it is machine-specific. The shared
# store location for worktrees/sandboxes is configured by scripts/setup-worktree.mjs
# via $ASSET_TRACKER_CACHE_ROOT, and in CI by actions/setup-node (cache: pnpm).
#
# pnpm uses an isolated node_modules by default; the Next.js + Prisma + Sentry
# build resolves cleanly under it. If a future dependency needs a package hoisted
# to the top level, add a `public-hoist-pattern[]=...` line here (last resort:
# `node-linker=hoisted`).

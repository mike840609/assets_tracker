# Local PostgreSQL used by `pnpm db:up`.
# Change POSTGRES_PASSWORD and both URLs together on a shared or public server.
POSTGRES_PASSWORD="postgres"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/asset_app?sslmode=disable"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/asset_app?sslmode=disable"

# For Neon, use a pooled runtime URL and an optional direct migration URL:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.HOST:5432/DATABASE?sslmode=require"
# DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Generate secrets with: openssl rand -hex 32
AUTH_SECRET="replace-with-long-random-secret"
CRON_SECRET="replace-with-long-random-secret"

# Google OAuth credentials.
AUTH_GOOGLE_ID="replace-with-google-oauth-client-id"
AUTH_GOOGLE_SECRET="replace-with-google-oauth-client-secret"

# Canonical URL used for metadata and OAuth deployments.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Host port used by the full Docker Compose profile.
APP_PORT="3000"
# Host port exposed for local database tools.
POSTGRES_PORT="5432"

# Optional stable OAuth callback proxy for hosted previews.
# AUTH_REDIRECT_PROXY_URL="https://stable-preview-host.example.com"

# Vercel environment: development | preview | production
# VERCEL_ENV="development"

# Required only when VERCEL_ENV=preview.
# PREVIEW_AUTH_PASSWORD="replace-with-preview-login-password"
# PREVIEW_AUTH_DISABLED="true"

# Optional Sentry integration. Leave all values unset for a complete no-op.
# SENTRY_DSN="https://<key>@<org>.ingest.<region>.sentry.io/<project-id>"
# NEXT_PUBLIC_SENTRY_DSN="https://<key>@<org>.ingest.<region>.sentry.io/<project-id>"
# SENTRY_AUTH_TOKEN="replace-with-sentry-auth-token"
# SENTRY_ORG="replace-with-sentry-org-slug"
# SENTRY_PROJECT="replace-with-sentry-project-slug"
# SENTRY_ALERT_USER_ID="replace-with-sentry-user-id"
# SENTRY_ALERT_TEAM_ID="replace-with-sentry-team-id"
# SENTRY_CAPTURE_WARNINGS="false"
# NEXT_PUBLIC_VERCEL_GIT_COMMIT_SHA=""

{
  "buildCommand": "npm run build:vercel",
  "regions": ["sin1"],
  "skewProtection": true,
  "crons": [
    {
      "path": "/api/cron/snapshot",
      "schedule": "30 21 * * *"
    }
  ],
  "functions": {
    "src/app/api/cron/snapshot/route.ts": { "maxDuration": 60 },
    "src/app/api/prices/refresh/route.ts": { "maxDuration": 60 },
    "src/app/api/exchange-rates/refresh/route.ts": { "maxDuration": 30 }
  }
}

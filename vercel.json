{
  "installCommand": "npm ci --prefer-offline --no-audit --no-fund",
  "buildCommand": "npm run build:vercel",
  "regions": ["sin1"],
  "crons": [
    {
      "path": "/api/cron/snapshot",
      "schedule": "30 21 * * *"
    }
  ],
  "functions": {
    "src/app/api/cron/snapshot/route.ts": { "maxDuration": 60 },
    "src/app/api/refresh/route.ts": { "maxDuration": 60 }
  }
}
